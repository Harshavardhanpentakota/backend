# ─────────────────────────────────────────────
# Hotel Abhitej Inn — Environment Configuration
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
NODE_ENV=development
PORT=5000
API_PREFIX=/api

# ── MongoDB ──────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/hotel_abhitej_inn

# ── JWT ──────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_change_in_production
JWT_REFRESH_EXPIRES_IN=30d

# ── Bcrypt ───────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ── CORS ─────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── Email (Nodemailer / SMTP) ─────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Hotel Abhitej Inn <noreply@hotelabhitejinn.com>

# ── Razorpay ─────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Logging ───────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs

# ── Hotel Details (used in PDF/emails) ────────
HOTEL_NAME=Hotel Abhitej Inn
HOTEL_ADDRESS=Near Jeypore Junction, Araku Village Mandal, Dumbriguda, Andhra Pradesh
HOTEL_PHONE=+91-XXXXXXXXXX
HOTEL_EMAIL=info@hotelabhitejinn.com
HOTEL_CHECKIN_TIME=12:00
HOTEL_CHECKOUT_TIME=10:00
